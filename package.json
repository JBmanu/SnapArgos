{
  "name": "snap-uploader",
  "version": "1.0.0",
  "description": "Snap! project asset uploader",
  "scripts": {
    "start": "npm run css:build && concurrently --names \"proxy,css\" --prefix-colors \"#ff6b35,#ffd166\" \"npm run proxy\" \"npm run css:watch\"",
    "proxy": "node proxy.js",
    "css:build": "tailwindcss -i src/css/input.css -o ./dist/output.css --minify",
    "css:watch": "tailwindcss -i src/css/input.css -o ./dist/output.css --watch",
    "build": "npm run css:build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4"
  }
}
